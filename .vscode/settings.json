{
    "chat.tools.terminal.autoApprove": {
        "trudag": true,
        "cargo check": true,
        "cargo clippy": true,
        "cargo test": true,
        "awk": true,
        "cargo audit": true,
        "cargo deny": true,
        "cargo fmt": true,
        "cargo doc": true,
        "act": true,
        "paste": true
    },
    // Exclude .actrc from YAML validation — it is a plain-text config file
    "files.associations": {
        ".actrc": "plaintext"
    },
    // Tell the YAML extension to ignore mkdocs custom tags
    "yaml.customTags": [
        "!ENV scalar",
        "!ENV sequence"
    ]
}